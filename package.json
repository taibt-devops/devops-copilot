{
  "name": "devops-copilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-user, read-only AI incident-response assistant on the Claude Agent SDK",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.186",
    "@aws-sdk/client-secrets-manager": "^3.1075.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
