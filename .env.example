# --- Claude auth (choose ONE) ---
# Max/Pro subscription token from `claude setup-token` (valid ~1 year, no auto-refresh).
CLAUDE_CODE_OAUTH_TOKEN=

# Anthropic API key — takes precedence if set; use for always-on/Phase 2 (no expiry).
# ANTHROPIC_API_KEY=

# --- App config ---
COPILOT_MODEL=claude-opus-4-8
COPILOT_PORT=8787
COPILOT_MAX_TURNS=35
# Hard wall-clock cap per question (ms): abort + return partial so it never hangs on "Thinking…".
COPILOT_REQUEST_TIMEOUT_MS=240000
COPILOT_SESSION_TTL_MIN=30

# --- MCP hub ---
# Path to the read-only MCP config the agent should load. For deploys, point at the
# committed template (deploy/mcp.template.json) whose token fields are ${VAR} placeholders.
# Leave blank to use only the app-local servers defined in src/mcp.ts.
COPILOT_MCP_CONFIG=

# --- Secrets (production) ---
# AWS Secrets Manager secret id/ARN holding a JSON of ENV_VAR->value (Claude + MCP tokens).
# The app reads it at boot and injects into the environment; the MCP template's ${VAR}
# placeholders then resolve. Keeps token values out of the image and .env. The only secret
# the host needs directly is an AWS credential to READ this secret (env keys / mounted
# ~/.aws on a VM, or an IAM role on EC2/EKS). Leave blank for local dev.
# COPILOT_SECRET_ID=devops-copilot/config

# Which servers to enable (comma-separated). "aws-api" is app-local (read-only
# AWS EC2/SSM visibility); the rest come from COPILOT_MCP_CONFIG.
COPILOT_MCP_SERVERS=grafana,opensearch,jenkins,kubernetes,backlog,aws-api

# --- Knowledge base ---
# Always-on context concatenated into the system prompt (keep small: topology, conventions).
COPILOT_KNOWLEDGE_DIR=./knowledge

# Source repos the agent may Grep/Glob/Read for code-level investigation (comma-separated).
# LOCAL DEV: point at your cloned repos (raw code is grep-able directly):
# COPILOT_CODE_DIRS=./source,/path/to/your/other-repos
# DOCKER: a host folder holding the cloned repos (raw code + overlaid curated docs) is
#   bind-mounted read-only at /srv/code; the agent Greps it directly. Keep it fresh with
#   `deploy/refresh-source.sh` on a cron (reads a READ-ONLY GitLab PAT from Secrets Manager).
#   No gitlab MCP server is used. (See deploy/README.md.)
# Runbooks fetched on demand via the fetch_skill tool (only their metadata is in the prompt).
COPILOT_SKILLS_DIR=./skills
# Tool results larger than this many chars are spilled to a temp file; the agent then
# pulls only the slice it needs via the read-only query_result tool.
COPILOT_SPILL_THRESHOLD=12000

# inspect_host: run an allowlisted READ-ONLY command on an EC2 host via SSM (to inspect
# services self-hosted on the host, e.g. RabbitMQ in Docker). Highest-trust feature —
# set to "false" to disable entirely. Needs ssm:SendCommand + ssm:GetCommandInvocation
# on the IAM identity (scope tightly in production / IRSA).
COPILOT_HOST_INSPECT=true
# Host command policy:
#   allowlist  (default, safest) = only known read-only commands.
#   permissive = run read/view freely, block only a destructive denylist
#                (kill/terminate/restart/rm/delete/format/stop/disable/install/writes).
#                NOT strictly read-only — accept that some mutating command may slip through.
COPILOT_HOST_MODE=allowlist

# --- RAG (semantic knowledge retrieval) — OPT-IN, default OFF ---
# When false: the search_knowledge tool is NOT registered; no Bedrock/S3 needed; the app
# runs on knowledge/ + skills/ only. When true: register search_knowledge (fail-soft).
COPILOT_RAG_ENABLED=false
# Embedding model on Bedrock. The provider (request/response shape) is auto-inferred from
# the id: ids with titan/amazon/nova -> Titan, otherwise Cohere. Index + query MUST use the
# same model. Cohere embed-v4/multilingual is great for mixed EN/VN, BUT Cohere is sold via
# AWS Marketplace and may be blocked in some countries ("offer not available in this country")
# — if you hit that, use Amazon Titan (no Marketplace, available everywhere):
#   amazon.titan-embed-text-v2:0   (1024-dim, verified working)
COPILOT_RAG_EMBED_MODEL=cohere.embed-v4:0
# How many chunks search_knowledge returns by default.
COPILOT_RAG_K=6
# Doc roots to index (comma-separated), used by `npm run ingest`.
COPILOT_RAG_SOURCES=./knowledge
# Vector store backend: local | s3-file | s3-vectors | opensearch
#   local      = file index in RAM (zero infra; dev). Persisted at COPILOT_RAG_LOCAL_PATH.
#   s3-file    = one index object in S3 (set COPILOT_RAG_BUCKET / _KEY).
#   s3-vectors = Amazon S3 Vectors native k-NN (set COPILOT_RAG_VECTOR_BUCKET / _INDEX).
#   opensearch = not implemented yet (R5).
COPILOT_RAG_STORE=local
COPILOT_RAG_LOCAL_PATH=./data/rag-index.json
# COPILOT_RAG_BUCKET=
# COPILOT_RAG_KEY=rag/index.json
# COPILOT_RAG_VECTOR_BUCKET=
# COPILOT_RAG_INDEX=devops-copilot
